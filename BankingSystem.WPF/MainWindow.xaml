<Window x:Class="BankingSystem.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BankingSystem.WPF"
        mc:Ignorable="d"
        Title="Banking System" Height="780" Width="920"
        Background="#F6F8FA">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D9DEE6"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D9DEE6"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#C5CED9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#334155"/>
        </Style>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  Padding="0,0,8,12"
                  Background="Transparent">
        <StackPanel Margin="14">

            <TextBlock FontSize="20" FontWeight="Bold"
                       Foreground="#1F2937"
                       Text="Banking System (MVVM)"
                       Margin="0,0,0,14"/>

            <!-- عملاء -->
            <TextBlock FontWeight="SemiBold" FontSize="14"
                       Foreground="#3F5F73"
                       Text="1) العملاء — بيانات + أزرار" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <StackPanel Margin="0,0,14,0" MinWidth="110">
                    <TextBlock FontSize="11" Foreground="#64748B" Text="Name" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Margin="0,0,14,0" MinWidth="56">
                    <TextBlock FontSize="11" Foreground="#64748B" Text="Age" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Age, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Margin="0,0,14,0" MinWidth="140">
                    <TextBlock FontSize="11" Foreground="#64748B" Text="Gender (1=Male, 2=Female)" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Gender, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Margin="0,0,14,0" MinWidth="200">
                    <TextBlock FontSize="11" Foreground="#64748B" Text="Address" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Margin="0,0,14,0" MinWidth="130">
                    <TextBlock FontSize="11" Foreground="#64748B" Text="National ID (14 digits, no duplicate)" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding NationalId, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Bottom" Margin="0,14,10,0">
                    <Button MinWidth="100" Padding="10,6" Margin="0,0,8,8" Content="Add Customer" Command="{Binding AddCustomerCommand}"/>
                    <Button MinWidth="100" Padding="10,6" Margin="0,0,8,0" Content="Edit Customer" Command="{Binding EditCustomerCommand}"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Bottom" Margin="0,14,0,0">
                    <Button MinWidth="100" Padding="10,6" Content="Close Customer" Command="{Binding CloseCustomerCommand}"/>
                </StackPanel>
            </StackPanel>

            <TextBlock FontWeight="SemiBold"
                       Foreground="#374151"
                       Text="القائمة — اختَر عميلاً" Margin="0,0,0,6"/>
            <ListBox Height="118" Margin="0,0,0,14"
                     ItemsSource="{Binding Customers}"
                     SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="Name: "/><Run Text="{Binding Name, Mode=OneWay}"/>
                            <Run Text=", National ID: "/><Run Text="{Binding NationalId, Mode=OneWay}"/>
                            <Run Text=", Closed: "/><Run Text="{Binding IsClosed, Mode=OneWay}"/>
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- حسابات -->
            <TextBlock FontWeight="SemiBold" FontSize="14"
                       Foreground="#3F5F73"
                       Text="2) الحسابات والحركات" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <StackPanel Margin="0,0,14,0" MinWidth="180">
                    <TextBlock FontSize="11" Foreground="#64748B" Text="Account type (1=Saving, 2=Salary)" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding AccountType, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Margin="0,0,14,0" MinWidth="110">
                    <TextBlock FontSize="11" Foreground="#64748B" Text="Initial balance" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding InitialBalance, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <Button VerticalAlignment="Bottom" MinHeight="36" Margin="0,16,24,0" Padding="14,8" Content="Add Account" Command="{Binding AddAccountCommand}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <StackPanel Margin="0,0,14,0" MinWidth="250">
                    <TextBlock FontSize="11" Foreground="#64748B" Text="Selected account ID (عمليات Deposit/Withdraw من هنا)" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding SelectedAccountId, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas"/>
                </StackPanel>
                <StackPanel Margin="0,0,14,0" MinWidth="250">
                    <TextBlock FontSize="11" Foreground="#64748B" Text="Transfer to account ID" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding TransferToAccountId, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas"/>
                </StackPanel>
                <StackPanel Margin="0,0,14,0" MinWidth="100">
                    <TextBlock FontSize="11" Foreground="#64748B" Text="Amount (L.E)" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Margin="0,0,8,0" MinWidth="80" Padding="10,8" Content="Deposit" Command="{Binding DepositCommand}"/>
                    <Button Margin="0,0,8,0" MinWidth="80" Padding="10,8" Content="Withdraw" Command="{Binding WithdrawCommand}"/>
                    <Button MinWidth="80" Padding="10,8" Content="Transfer" Command="{Binding TransferCommand}"/>
                </StackPanel>
            </StackPanel>

            <!-- شهادات -->
            <TextBlock FontWeight="SemiBold" FontSize="14"
                       Foreground="#3F5F73"
                       Text="3) الشهادات (سنوات: 1 / 3 / 5 ، سعر مضاعف 1000)" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <StackPanel Margin="0,0,14,0" MinWidth="220">
                    <TextBlock FontSize="11" Foreground="#64748B" Text="Certificate period (years: 1, 3, 5)" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding CertificatePeriod, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Margin="0,0,14,0" MinWidth="120">
                    <TextBlock FontSize="11" Foreground="#64748B" Text="Price (L.E)" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding CertificatePrice, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Margin="0,0,14,0" MinWidth="260">
                    <TextBlock FontSize="11" Foreground="#64748B" Text="Selected certificate ID (للتعديل/الحذف)" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding SelectedCertificateId, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Margin="0,0,8,0" MinWidth="100" Padding="10,8" Content="Create" Command="{Binding CreateCertificateCommand}"/>
                    <Button Margin="0,0,8,0" MinWidth="100" Padding="10,8" Content="Update" Command="{Binding UpdateCertificateCommand}"/>
                    <Button MinWidth="100" Padding="10,8" Content="Delete" Command="{Binding DeleteCertificateCommand}"/>
                </StackPanel>
            </StackPanel>

            <!-- كارت ائتمان -->
            <TextBlock FontWeight="SemiBold" FontSize="14"
                       Foreground="#3F5F73"
                       Text="4) كارت ائتمان (حدّ 50000–250000 ، كارت واحد للعميل)" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <StackPanel Margin="0,0,14,0" MinWidth="140">
                    <TextBlock FontSize="11" Foreground="#64748B" Text="Cash limit (L.E)" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding CreditCardLimit, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <Button VerticalAlignment="Bottom" Margin="0,16,10,0" MinWidth="150" Padding="12,8" Content="Create card" Command="{Binding CreateCreditCardCommand}"/>
                <Button VerticalAlignment="Bottom" Margin="0,16,0,0" MinWidth="160" Padding="12,8" Content="Update limit" Command="{Binding UpdateCreditCardCommand}"/>
            </StackPanel>

            <!-- تقارير -->
            <TextBlock FontWeight="SemiBold" FontSize="14"
                       Foreground="#3F5F73"
                       Text="5) التقارير والإحصائيات" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Button Margin="0,0,10,0" MinWidth="220" Padding="12,10" Content="Customer report / الرصيد" Command="{Binding GenerateCustomerReportCommand}"/>
                <Button MinWidth="220" Padding="12,10" Content="Bank statistics" Command="{Binding GenerateStatisticsCommand}"/>
            </StackPanel>

            <TextBlock FontWeight="SemiBold"
                       Foreground="#374151"
                       Text="Transactions (للعميل المختار)" Margin="0,0,0,6"/>
            <ListBox Height="110" Margin="0,0,0,12" ItemsSource="{Binding CustomerTransactions}"/>

            <TextBlock FontWeight="SemiBold"
                       Foreground="#374151"
                       Text="Service activities" Margin="0,0,0,6"/>
            <ListBox Height="110" Margin="0,0,0,12" ItemsSource="{Binding CustomerServiceActivities}"/>

            <TextBlock FontWeight="SemiBold"
                       Foreground="#374151"
                       Text="حالة / رسالة" Margin="0,0,0,6"/>
            <Border BorderBrush="#D9DEE6" BorderThickness="1" Padding="12" Background="#EFF3F7" CornerRadius="4">
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="{Binding MessageForeground}"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
